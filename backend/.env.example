# Banco de dados (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Z-API - Conexão WhatsApp
ZAPI_INSTANCE_ID="sua_instance_id"
ZAPI_TOKEN="seu_token_zapi"
ZAPI_BASE_URL="https://api.z-api.io/instances"

# Segurança
WEBHOOK_SECRET="sua_chave_secreta_aqui"
PORT=3000

# Nome da barbearia (aparece nas mensagens do bot)
BARBER_NAME="Barbearia do João"

# Número do WhatsApp do atendente humano (com DDI+DDD, sem símbolos)
HUMAN_ATTENDANT_PHONE="5581999999999"
